# ============================================================
# Backend — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Servidor ---
NODE_ENV=development
PORT=4000
API_VERSION=v1

# --- Base de Datos (PostgreSQL / Supabase) ---
# Para Supabase: DATABASE_URL es la que usa Prisma directamente
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres?sslmode=require
# Config individual (usa DATABASE_URL en lugar de estas para Prisma)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plataforma_turisticas
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# --- JWT (¡Cambiar secreto en producción!) ---
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_32_caracteres
JWT_EXPIRES_IN=7d

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logger ---
LOG_LEVEL=debug

# --- Google Gemini (IA para chatbot) ---
GEMINI_API_KEY=

# --- Brevo (email transaccional vía SMTP) ---
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=tu_correo_brevo@ejemplo.com
MAIL_PASS=tu_clave_SMTP_de_brevo
MAIL_FROM=noreply@lasrocas

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Cloudinary (imágenes) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Turnstile (CAPTCHA) ---
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
